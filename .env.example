# ============================================================================
# PMO 智能座舱 — 环境变量样板
# 用法：cp .env.example .env  然后按需填写
# ============================================================================

# ---------- 端口 ----------
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ---------- 浏览器侧访问后端的 URL ----------
# 本机部署：保留默认即可
# 远程部署：改为 http://<你的服务器IP或域名>:8000
PUBLIC_API_BASE=http://localhost:8000

# ---------- 跨域白名单（多个用逗号分隔，"*" 表示允许全部但会关闭 credentials） ----------
NEWERA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------- PostgreSQL ----------
POSTGRES_DB=pmo
POSTGRES_USER=pmo
POSTGRES_PASSWORD=change_me_in_production

# ---------- 持久化 / 队列 ----------
NEWERA_STATE_STORE_MODE=postgres
NEWERA_QUEUE_PROVIDER=redis
NEWERA_SNAPSHOT_KEY=default

# ---------- 飞书集成（全部可选，留空则降级为本地 mock 模式） ----------
LARK_APP_ID=
LARK_APP_SECRET=
LARK_BOT_WEBHOOK_URL=
LARK_TASK_WEBHOOK_URL=
LARK_TASKLIST_GUID=
LARK_DOC_FOLDER_TOKEN=

# 提供方切换：local（本地 mock）/ lark（真实飞书）/ lark_webhook / lark_task_api
NEWERA_DELIVERY_PROVIDER=local
NEWERA_NOTIFICATION_PROVIDER=local
NEWERA_OPS_TASK_PROVIDER=local

# 启动严格模式：true 时凭证未配置会拒绝启动，false 时降级运行
NEWERA_STARTUP_STRICT=false
